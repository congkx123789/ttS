{
  "manifest_version": 3,
  "name": "Trợ Lý Dịch & Đọc Truyện",
  "version": "1.0.0",
  "description": "Tiện ích Chrome hỗ trợ dịch và đọc truyện chữ với trợ lý AI.",
  "icons": {
    "16": "logo.png",
    "48": "logo.png",
    "128": "logo.png"
  },
  "options_page": "options.html",
  "action": {
    "default_popup": "index.html",
    "default_icon": "logo.png"
  },
  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "identity"
  ],
  "host_permissions": [
    "http://localhost/*"
  ],
  "oauth2": {
    "client_id": "846826769861-s88vrg8okk1n71im3pv2oruembouklc1.apps.googleusercontent.com",
    "scopes": ["email", "profile"]
  },
  "background": {
    "service_worker": "src/background.js",
    "scripts": ["src/background.js"]
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "tro-ly-dich-doc-truyen@alida.org",
      "strict_min_version": "126.0",
      "data_collection_permissions": {
        "required": [
          "none"
        ]
      }
    }
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["dictionaries/*"],
      "matches": ["<all_urls>"]
    }
  ]
}
